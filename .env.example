# Node API (see server/index.js)
PORT=3001
NODE_ENV=development

# MySQL — optional until you implement persistence; server runs without these.
# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=
# DB_PASSWORD=
# DB_NAME=ebb_rocks

# Frontend (Vite) — leave empty to use same-origin `/api` (dev proxy handles it).
# VITE_API_BASE_URL=
